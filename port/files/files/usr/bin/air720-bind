#!/bin/sh

set -eu

VID="${AIR720_VID:-1286}"
PID="${AIR720_PID:-4e3d}"

modprobe option 2>/dev/null || true

usbdev=''
for p in /sys/bus/usb/devices/*; do
	[ -r "$p/idVendor" ] && [ -r "$p/idProduct" ] || continue
	v="$(tr 'A-F' 'a-f' < "$p/idVendor")"
	q="$(tr 'A-F' 'a-f' < "$p/idProduct")"
	if [ "$v" = "$VID" ] && [ "$q" = "$PID" ]; then
		usbdev="$p"
		break
	fi
done

if [ -z "$usbdev" ]; then
	echo "Air720S/SL USB device ${VID}:${PID} was not found." >&2
	exit 1
fi

echo "Air720S/SL detected at ${usbdev##*/} (${VID}:${PID})"
echo "Composite interfaces:"
for intf in "$usbdev":*; do
	[ -d "$intf" ] || continue
	ifnum="$(cat "$intf/bInterfaceNumber" 2>/dev/null || echo '?')"
	driver="$(basename "$(readlink -f "$intf/driver" 2>/dev/null || echo unbound)")"
	printf '  interface=%-3s driver=%s\n' "$ifnum" "$driver"
done

echo
if air720-ports; then
	exit 0
fi

cat >&2 <<'MSG'
The modem is present but no Air720 ttyUSB port is bound.

Do not use option1/new_id as the primary workaround for 1286:4e3d: dynamic
IDs do not carry the Air720 RSVD(0)|RSVD(1)|ZLP driver_info flags and may bind
the RNDIS/ECM interfaces or reproduce PPP bulk-transfer failures.

Check:
  dmesg | tail -100
  lsmod | grep -E 'option|usb_wwan|usbserial'

The AAOP kernel patch should add 1286:4e3d statically to option.c with
RSVD(0)|RSVD(1)|ZLP.
MSG
exit 2
