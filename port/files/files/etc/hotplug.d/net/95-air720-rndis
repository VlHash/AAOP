#!/bin/sh

[ -n "$INTERFACE" ] || exit 0

case "$ACTION" in
	remove)
		configured="$(uci -q get air720.main.rndis_device || true)"
		[ "$configured" = "$INTERFACE" ] && ifdown cellular6 >/dev/null 2>&1 || true
		exit 0
		;;
	add) ;;
	*) exit 0 ;;
esac

[ "$(uci -q get air720.main.rndis_ipv6 || echo 1)" = 1 ] || exit 0
[ -e "/sys/class/net/$INTERFACE/device/driver" ] || exit 0

driver="$(basename "$(readlink -f "/sys/class/net/$INTERFACE/device/driver")")"
case "$driver" in
	rndis_host|cdc_ether) ;;
	*) exit 0 ;;
esac

# Restrict this hook to the Luat Air720S/SL USB device 1286:4e3d.
p="$(readlink -f "/sys/class/net/$INTERFACE/device")"
match=0
while [ -n "$p" ] && [ "$p" != / ]; do
	if [ -r "$p/idVendor" ] && [ -r "$p/idProduct" ]; then
		vid="$(tr 'A-F' 'a-f' < "$p/idVendor")"
		pid="$(tr 'A-F' 'a-f' < "$p/idProduct")"
		[ "$vid" = 1286 ] && [ "$pid" = 4e3d ] && match=1
		break
	fi
	p="${p%/*}"
	[ -n "$p" ] || p=/
done
[ "$match" -eq 1 ] || exit 0

# The RNDIS/ECM netdev reappearing is the reliable userspace signal that the
# Air720SL composite USB device has enumerated again after a modem reset.
#
# Recover CID5/RNDIS IPv6 first. In hybrid mode, then re-run the native PPP
# helper as well: it re-discovers USB interface 03, refreshes network.cellular,
# and invokes netifd's native proto ppp path, whose connect script recreates
# CID1 as IP and dials *99#. This makes a manual Air720SL reset self-recovering
# without requiring a GPIO reset line on the M31 host.
(
	/usr/bin/air720-rndis6 start "$INTERFACE" >/tmp/air720-rndis6-hotplug.log 2>&1
	rc=$?

	if [ "$rc" -eq 0 ]; then
		mode="$(uci -q get air720.main.mode || echo hybrid)"
		case "$mode" in
			hybrid)
				logger -t air720-hotplug \
					"Air720SL USB network function re-added; restoring native PPP IPv4" \
					2>/dev/null || true
				/usr/bin/air720-ppp start >>/tmp/air720-ppp-hotplug.log 2>&1 || \
					logger -t air720-hotplug \
						"PPP IPv4 recovery failed after Air720SL USB re-enumeration" \
						2>/dev/null || true
				;;
		esac
	fi
) &

exit 0
